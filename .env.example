# NestJS 中文文档 AI 翻译配置
# 复制此文件为 .env 并配置

# =============================================================================
# NVIDIA NIM API 配置（当前使用的翻译引擎）
# =============================================================================

# NVIDIA API 密钥
# 获取地址: https://build.nvidia.com/
# NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here

# =============================================================================
# 使用说明
# =============================================================================

# 1. 获取 NVIDIA NIM API Key
# 2. 取消注释 NVIDIA_API_KEY 并填入 Key
# 3. 保存文件
# 4. 运行翻译命令:
#    bun scripts/cli.ts translate --verbose    # 推荐: 统一 CLI
#    bun scripts/translate-docs.ts --verbose   # 兼容: 直接脚本
#
# 常用命令:
#    bun scripts/cli.ts translate --resume     # 断点续传
#    bun scripts/cli.ts translate --force      # 强制重新翻译
#    bun scripts/cli.ts check                  # 检查翻译质量
#    bun scripts/cli.ts fix                    # 修复格式问题
