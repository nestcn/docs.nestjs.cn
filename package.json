{
  "name": "nestjsdocs",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run check-links && rspress build && tsx scripts/copy-assets.ts",
    "dev": "rspress dev",
    "preview": "rspress preview",
    "fix-code-blocks": "tsx scripts/fix-code-blocks.ts",
    "fix-links": "tsx scripts/fix-links.ts",
    "validate-translation": "tsx scripts/validate-translation.ts",
    "fix-all": "npm run fix-code-blocks && npm run fix-links",
    "translate-docs": "bun scripts/translate-docs.ts",
    "translate-docs:verbose": "bun scripts/translate-docs.ts --verbose",
    "translate-docs:dry-run": "bun scripts/translate-docs.ts --dry-run",
    "translate-docs:force": "bun scripts/translate-docs.ts --force",
    "translate-docs:no-ai": "bun scripts/translate-docs.ts --no-ai",
    "translate-docs:mistral": "bun scripts/translate-docs.ts --model @cf/mistral/mistral-7b-instruct-v0.1 --verbose",
    "translate-docs:openchat": "bun scripts/translate-docs.ts --model @cf/chatchat/openchat-3.5-0106 --verbose",
    "translate-docs:single": "bun scripts/translate-single.ts",
    "check-placeholders": "tsx scripts/check-placeholders.ts",
    "sync-and-translate": "npm run translate-docs && npm run fix-all",
    "sync-and-translate:no-ai": "npm run translate-docs:no-ai && npm run fix-all",
    "update-sync-time": "bun scripts/update-sync-time.ts",
    "check-links": "bun scripts/check-links.ts",
    "check-internal-links": "bun scripts/check-internal-links.ts",
    "check-translation-integrity": "bun scripts/check-translation-integrity.ts",
    "check-translation-integrity:verbose": "bun scripts/check-translation-integrity.ts --verbose"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.10",
    "@rspress/core": "^2.0.3",
    "@rspress/plugin-client-redirects": "^2.0.4",
    "dotenv": "^17.3.1",
    "glob": "^11.1.0",
    "hono": "^4.12.5",
    "p-limit": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "markdown-link-check": "^3.14.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
